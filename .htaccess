# OPTIMIZED .HTACCESS FOR DOCKER / RENDER

<IfModule mod_authz_core.c>
    Require all granted
</IfModule>

Options +FollowSymLinks -Indexes
RewriteEngine On
RewriteBase /

# ۱. پاسخ سبک به ریشه سایت فقط برای رفع ارور Health Check (بدون رپیدایرکت)
RewriteRule ^$ - [R=200,L]

# ۲. مسدود کردن درخواست‌های زیرنویس اضافی
RewriteCond %{REQUEST_URI} \.(srt|ssa|ass|sub|smi|txt|idx|mpl|vtt|psb|sami|pjs|sup)$ [NC]
RewriteRule ^(movie|series|live)/ - [F,L]

# ۳. مسیر فیلم‌ها به فایل play.php
RewriteRule ^movie/.*/([0-9]+)$ play.php?movieId=$1 [QSA,L]

# ۴. مسیر سریال‌ها به فایل play.php
RewriteRule ^series/.*/([0-9]+)\.(.+)$ play.php?type=series&movieId=$1&data=$2 [QSA,L]

# ۵. مسیر پخش زنده به فایل live_play.php
RewriteRule ^live/.*/([0-9]+)\.[a-z0-9]+$ live_play.php?streamId=$1 [QSA,L]

# ۶. آدرس‌های عددی خالص استریم
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(live|stream)/.*/([0-9]+)$ live_play.php?streamId=$2 [QSA,L]

# ۷. میانبرهای m3u8 برای Player API
RewriteRule ^tv\.m3u8$ player_api.php?action=get_live_streams&type=m3u8 [QSA,L]
RewriteRule ^movies\.m3u8$ player_api.php?action=get_vod_streams&type=m3u8 [QSA,L]
